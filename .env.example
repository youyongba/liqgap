# ============================================================================
# liq-gap · 本地环境变量（开发默认值 · development defaults）
#
# 这份 .env 由 dotenv 在 server.js 启动时自动加载。
# 不要把真实密钥提交到 git —— 已经在 .gitignore 中排除（excluded by .gitignore）。
# ============================================================================

# ---- 服务端口 (Server Port) -------------------------------------------------
# 后端监听端口，默认 3000；改这里之后浏览器访问相应端口即可。
PORT=3003

# 运行模式 (Run Mode)：development（开发） / production（生产）
NODE_ENV=production


# 如何获取 URL:
#   飞书群 → 设置 → 群机器人 → 添加机器人 → "自定义机器人"
#   复制 webhook 地址粘贴到这里。
#   若勾选了 "签名校验"，请同时填 FEISHU_WEBHOOK_SECRET。
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/cbbf7949-e7f5-4dd6-a257-d6e018ae563c
FEISHU_WEBHOOK_SECRET=IVO6tQ1vjxOyALOCPvZN5d

# 飞书推送策略：
#   - LONG/SHORT 交易信号卡：关掉（觉得是噪音）
#   - FVG 缺口卡：保留，但仅 1h 级别触发（红/绿 FVG）；
#     1h 限制在 routes/klines.js 中硬编码，FEISHU_FVG_NOTIFY_ENABLED 留空 = 默认开启。
# regime webhook (monitor.24os.cn) 走自己的逻辑，照常驱动自动交易。
# 手动 /api/notify/test、/api/notify/signal 仍可用。
# FEISHU_SIGNAL_NOTIFY_ENABLED=false
# FEISHU_FVG_NOTIFY_ENABLED=false   # 想彻底关 FVG 推送时再打开此行


# ============================================================================
# Binance 合约 API 凭证 (Futures API Credentials · 可选/optional)
#
# 仅当你想拉取真实强平数据 (real liquidation data,
# /fapi/v1/allForceOrders) 时才需要填写。
# 不填的话，/api/squeeze/* 会自动降级（degraded fallback）为基于
# OI / 资金费率 / 持仓比的方案，项目仍可正常运行。
#
# 申请方式 (How to apply)：
#   登录 binance.com -> API Management -> Create API
# 安全提示 (Security tip)：
#   只勾选 Read-only（只读）权限，
#   不要勾选 Enable Trading / Withdraw（交易 / 提现）。
# ============================================================================
BINANCE_API_KEY=H4qsWRDJidHYEngZeOEgEpq53btVwzpv5LvmMNkxUCClzDYvpuZEGgfZbiUjo4Pp
BINANCE_API_SECRET=4ymlNJ62Rv4v1q6ZUFRu5x4eNOqpexx3PkB2gHznWssQuuxZb4MlvKCnFug8a1u5

# ============================================================================
# Regime 接口 (Market-state Webhook · 可选/optional)
#
# 当一小时 K 线检测到「新出现」的 FVG 时，会自动 POST 通知此 URL，
# 让外部 regime 服务感知方向。请求体固定为：
#   bullish FVG → { "fvg": "long" }
#   bearish FVG → { "fvg": "short" }
#
# 留空则不通知（仅飞书推送照常生效）。
# (Leave blank to disable; Feishu push still works independently.)
# ============================================================================
REGIME_API_URL=https://monitor.24os.cn/api/auto-trade/fvg-signal
REGIME_API_METHOD=POST
REGIME_API_TOKEN=wh_d113d9b4d838dbd635d4c19c3f0c51d9
REGIME_NOTIFY_ENABLED=true


AITRADE_API_URL=https://aitrade.24os.cn

# ============================================================================
# 自动交易 Webhook (Auto-Trade · 由清算反转信号触发挂单)
#
# 当 routes/liqSignal.js 产出高置信度的 LIQ_REVERSAL_LONG / LIQ_REVERSAL_SHORT
# 信号时，本服务会异步 POST 一份挂单 payload 到下面的 URL；对方系统
# (aitrade.24os.cn 或自部署) 收到后下挂单。
#
# 触发示例 (Trigger example)：
#   curl -X POST https://aitrade.24os.cn/api/auto-trade/pending-order \
#     -H 'Content-Type: application/json' \
#     -H 'X-Auth-Token: <AUTO_TRADE_API_TOKEN>' \
#     -d '{"direction":"short","source":"liq-signal","label":"BTCUSDT-LIQ_REVERSAL_SHORT"}'
#
# 推送时机由 services/autoTrade.js 内部把关：
#   - signal ∈ AUTO_TRADE_TRIGGER_SIGNALS (默认 REVERSAL 两类)
#   - confidence >= AUTO_TRADE_MIN_CONFIDENCE (默认 75)
#   - 同 symbol+direction 处于冷却外 (默认 30 min)
#
# 留空 AUTO_TRADE_API_URL 则整体 no-op，不会影响其他功能。
# ============================================================================
AUTO_TRADE_API_URL=https://monitor.24os.cn/api/auto-trade/pending-order
AUTO_TRADE_API_TOKEN=54006625db5c6a03b3ba5e112b326eb69e4828ba00c5efab403c03e217263455
AUTO_TRADE_ENABLED=true
# CSV，触发该 webhook 的信号白名单（默认仅 REVERSAL 两类，最稳的高胜率 setup）
AUTO_TRADE_TRIGGER_SIGNALS=LIQ_REVERSAL_LONG,LIQ_REVERSAL_SHORT
# 触发的最低置信度 (与 LIQ_SIGNAL_MIN_CONFIDENCE=75 同步推荐)
AUTO_TRADE_MIN_CONFIDENCE=75
# 同 symbol+direction 推送冷却毫秒 (默认 30 min)，避免高频重复挂单
AUTO_TRADE_COOLDOWN_MS=1800000
# payload.source 的值
AUTO_TRADE_SOURCE=liq-signal
# payload.label 模板，支持 {symbol} {direction} {signal} {confidence}
AUTO_TRADE_LABEL_TEMPLATE={symbol}-{signal}
# 调试日志：'true' 时每次"被冷却跳过"也打日志
AUTO_TRADE_DEBUG=true


# ============================================================================
# HTTP 代理 (HTTP Proxy · 可选/optional)
#
# 如果你所在的网络无法直连 api.binance.com / fapi.binance.com，
# 可以在这里设置代理，axios 会自动识别 (auto-detected by axios)。
# 例 (example)：HTTPS_PROXY=http://127.0.0.1:7890
# ============================================================================
# HTTPS_PROXY=
# HTTP_PROXY=
# NO_PROXY=localhost,127.0.0.1
