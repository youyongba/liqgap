# ============================================================================
# liq-gap · 环境变量模板 (Environment Variables Template)
#
# 复制为 .env 后再填写 (copy then edit)：
#   cp .env.example .env
# ============================================================================

# 服务端口 (Server Port)
PORT=3000

# 运行模式 (Run Mode): development / production
NODE_ENV=development

# ---- Binance 合约鉴权 (Futures Auth · 可选/optional) -----------------------
# 仅 /api/squeeze/* 拉取真实强平数据 (real liquidation data) 时需要。
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- 飞书自定义机器人推送 (Feishu / Lark webhook · 可选/optional) -----------
# 配置后，/api/trade/signal 在出现 LONG/SHORT 信号且方向变化时会自动推送卡片，
# 也可通过 /api/notify/signal 手动推送，/api/notify/test 验证 webhook 是否可达。
#
# 如何获取 (How to obtain):
#   飞书群 → 设置 → 群机器人 → 添加机器人 → "自定义机器人"
#   复制 webhook URL 粘贴到 FEISHU_WEBHOOK_URL；
#   若勾选 "签名校验" 请同时填 FEISHU_WEBHOOK_SECRET。
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
# 关闭整体推送 (set to 'false' to disable feishu push entirely)
# FEISHU_NOTIFY_ENABLED=false
# 同方向推送冷却毫秒 (cooldown ms · 默认 1800000 = 30 分钟)
# FEISHU_NOTIFY_COOLDOWN_MS=1800000

# ---- 网络代理 (Network Proxy · 可选/optional) -------------------------------
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
