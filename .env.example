# ============================================================================
# liq-gap · 环境变量模板 (Environment Variables Template)
#
# 复制为 .env 后再填写 (copy then edit)：
#   cp .env.example .env
# ============================================================================

# 服务端口 (Server Port)
PORT=3000

# 运行模式 (Run Mode): development / production
NODE_ENV=development

# ---- Binance 合约鉴权 (Futures Auth · 可选/optional) -----------------------
# 仅 /api/squeeze/* 拉取真实强平数据 (real liquidation data) 时需要。
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- 网络代理 (Network Proxy · 可选/optional) -------------------------------
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
