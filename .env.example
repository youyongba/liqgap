# ============================================================================
# liq-gap · 环境变量模板 (Environment Variables Template)
#
# 复制为 .env 后再填写 (copy then edit)：
#   cp .env.example .env
# ============================================================================

# 服务端口 (Server Port)
PORT=3000

# 运行模式 (Run Mode): development / production
NODE_ENV=development

# ---- Binance 合约鉴权 (Futures Auth · 可选/optional) -----------------------
# 仅 /api/squeeze/* 拉取真实强平数据 (real liquidation data) 时需要。
BINANCE_API_KEY=
BINANCE_API_SECRET=

# ---- 飞书自定义机器人推送 (Feishu / Lark webhook · 可选/optional) -----------
# 配置后，/api/trade/signal 在出现 LONG/SHORT 信号且方向变化时会自动推送卡片，
# 也可通过 /api/notify/signal 手动推送，/api/notify/test 验证 webhook 是否可达。
#
# 如何获取 (How to obtain):
#   飞书群 → 设置 → 群机器人 → 添加机器人 → "自定义机器人"
#   复制 webhook URL 粘贴到 FEISHU_WEBHOOK_URL；
#   若勾选 "签名校验" 请同时填 FEISHU_WEBHOOK_SECRET。
FEISHU_WEBHOOK_URL=
FEISHU_WEBHOOK_SECRET=
# 关闭整体推送 (set to 'false' to disable feishu push entirely)
# FEISHU_NOTIFY_ENABLED=false
# 仅关闭 LONG/SHORT 交易信号自动推送（FVG / 手动 / 测试不受影响）
# (Disable auto-push of LONG/SHORT trade-signal cards only.)
# FEISHU_SIGNAL_NOTIFY_ENABLED=false
# 仅关闭 FVG 缺口卡自动推送（regime webhook / 手动 / 测试不受影响）
# (Disable auto-push of FVG cards to Feishu only;
#  regime webhook still fires and auto-trade still works.)
# FEISHU_FVG_NOTIFY_ENABLED=false
# 同方向推送冷却毫秒 (cooldown ms · 默认 1800000 = 30 分钟)
# FEISHU_NOTIFY_COOLDOWN_MS=1800000

# ---- Regime 接口 (Market-state webhook · 可选/optional) ---------------------
# 当 1h K 线检测到「新出现」的 FVG 时，自动 POST 通知到此 URL，让外部 regime
# 服务（如自定义 market-state 模型）感知 long/short 偏向。
# (When a brand-new FVG appears on the 1h timeframe, POST to this URL.)
#
# 请求体 (Request body):
#   bullish FVG → { "fvg": "long" }
#   bearish FVG → { "fvg": "short" }
#
# 留空或注释掉则跳过通知 (leave blank to disable)。
REGIME_API_URL=/api/auto-trade/fvg-signal
# 默认 POST，可改 GET（GET 时参数会拼到 query string 上）
# REGIME_API_METHOD=POST
# 可选 Bearer Token (optional bearer token, sent as `Authorization: Bearer <x>`)
# REGIME_API_TOKEN=
# 显式关闭整体通知 (set to 'false' to disable regime notify entirely)
# REGIME_NOTIFY_ENABLED=false

# ---- 网络代理 (Network Proxy · 可选/optional) -------------------------------
# HTTPS_PROXY=http://127.0.0.1:7890
# HTTP_PROXY=http://127.0.0.1:7890
# NO_PROXY=localhost,127.0.0.1
